# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Where fetched/derived data lives. Relative ./data is the default;
# override only if data lives outside the repo.
DATA_DIR=./data

# SEC EDGAR requires a descriptive User-Agent with contact info on all
# programmatic requests (used only if/when filings are fetched by script).
# Format: "project-name your.email@example.com"
SEC_EDGAR_USER_AGENT=mtg-commercial-analytics you@example.com
