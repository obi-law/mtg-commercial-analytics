                  <zone h='49657' id='8' param='horz' type-v2='layout-flow' w='98770' x='615' y='21417'>
                    <zone fixed-size='626' h='49657' id='9' is-fixed='true' name='EV vs Price' w='49385' x='615' y='21417'>
                      <layout-cache minwidth='286' type-h='cell' type-w='scalable' />
                      <zone-style>
                        <format attr='border-color' value='#000000' />
                        <format attr='border-style' value='none' />
