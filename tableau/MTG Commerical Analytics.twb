      <aliases enabled='yes' />
      <column caption='EV / Price (Nominal)' datatype='real' default-format='*0.00&quot;×&quot;' name='[Calculation_0858190739009536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[ev] / [sealed_price_usd]' />
      </column>
      <column caption='EV / Price (Realizable)' datatype='real' default-format='*0.00&quot;×&quot;' name='[Calculation_0858190739124225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[ev_realizable] / [sealed_price_usd]' />
      </column>
      <column caption='Value Verdict' datatype='string' name='[Calculation_0858190739177474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ev_realizable] &gt;= [sealed_price_usd] &#13;&#10;    THEN &quot;Realizable EV ≥ Price&quot; &#13;&#10;    ELSE &quot;Price exceeds Realizable EV&quot; &#13;&#10;END' />
      </column>
      <column caption='Median Realizable Ratio' datatype='real' default-format='*0.00&quot;×&quot;' name='[Calculation_1856547897282560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([Calculation_0858190739124225])' />
      </column>
      <column caption='Sets Above Price (Realizable)' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_1856547897389057]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [ev_realizable] &gt;= [sealed_price_usd] &#13;&#10;        THEN 1 &#13;&#10;    ELSE 0 &#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Total Sets' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_1856547897581570]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([set_code])' />
      </column>
      <column caption='Median Nominal Ratio' datatype='real' default-format='*0.00&quot;×&quot;' name='[Calculation_1856547897630723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([Calculation_0858190739009536])' />
      </column>
      <column caption='Dumbbell Sort Key' datatype='real' name='[Calculation_2257594405146624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 1&#13;&#10;    THEN SUM([ev_realizable]) / SUM([sealed_price_usd])&#13;&#10;ELSE SUM([ev])&#13;&#10;END' />
      </column>
