      <aliases enabled='yes' />
      <column caption='Slot Group' datatype='string' name='[Calculation_1307616343023616]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([sheet]), &quot;specialguest&quot;) OR CONTAINS(LOWER([sheet]), &quot;list&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;breakingnews&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;mysticalarchive&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;sourcematerial&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;throughtheages&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;legendaryturtle&quot;)&#13;&#10;    THEN &quot;Special Guest / Bonus&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;wildcard&quot;) &#13;&#10;    THEN &quot;Wildcard&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;land&quot;) OR CONTAINS(LOWER([sheet]), &quot;basic&quot;) &#13;&#10;    THEN &quot;Common / Uncommon / Land&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;foil&quot;) &#13;&#10;    THEN &quot;Foil&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;rare&quot;) OR CONTAINS(LOWER([sheet]), &quot;mythic&quot;) &#13;&#10;    THEN &quot;Rare / Mythic&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;common&quot;) OR CONTAINS(LOWER([sheet]), &quot;uncommon&quot;) &#13;&#10;    THEN &quot;Common / Uncommon / Land&quot;&#13;&#10;ELSE &quot;Other&quot; // nothing should hit Other&#13;&#10;END' />
      </column>
      <column caption='Slot Sort Key' datatype='real' name='[Calculation_2257594405265409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 1&#13;&#10;    THEN SUM([slot_ev_realizable_contribution]) / MIN([sealed_price_usd])&#13;&#10;ELSE SUM([slot_ev_contribution])&#13;&#10;END' />
      </column>
      <column caption='ev_by_slot.csv' datatype='table' name='[__tableau_internal_object_id__].[ev_by_slot.csv_96BFD7303FDC470081B5BBC9D24C113B]' role='measure' type='quantitative' />
