    <worksheet name='EV vs Price'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#edf1f6' fontname='Oswald' fontsize='14'>EV vs. Sealed Price</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#edf1f6' fontname='Oswald' fontsize='8'>Æ </run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#e8b04b' fontname='Montserrat' fontsize='12'>● EV Nominal</run>
            <run fontalignment='1' fontcolor='#8a97a8' fontname='Montserrat' fontsize='12'>Æ    </run>
