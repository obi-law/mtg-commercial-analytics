                      </zone-style>
                    </zone>
                    <zone h='49657' id='12' name='EV by Slot' w='49385' x='50000' y='21417'>
                      <layout-cache minwidth='278' type-h='fixed' type-w='scalable' />
                      <zone-style>
                        <format attr='border-color' value='#000000' />
                        <format attr='border-style' value='none' />
                        <format attr='border-width' value='0' />
