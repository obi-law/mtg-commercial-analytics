                  <zone fixed-size='102' forceUpdate='true' h='9167' id='3' is-fixed='true' type-v2='text' w='98770' x='615' y='667'>
                    <formatted-text>
                      <run fontalignment='1' fontcolor='#edf1f6' fontname='Oswald' fontsize='26'>MAGIC: THE GATHERING — BOOSTER VALUE VS. PRICE</run>
                      <run fontalignment='1'>Æ&#10;</run>
                      <run fontalignment='1' fontcolor='#8a97a8' fontname='Montserrat' fontsize='12'>Most Play Boosters look +EV on paper.</run>
                      <run fontalignment='1'>Æ&#10;</run>
                      <run fontalignment='1' fontcolor='#8a97a8' fontname='Montserrat' fontsize='12'>Once you discount the bulk you can&apos;t sell, the typical pack is worth less than it costs.</run>
                    </formatted-text>
                    <zone-style>
                      <format attr='border-color' value='#000000' />
                      <format attr='border-style' value='none' />
                      <format attr='border-width' value='0' />
                      <format attr='margin' value='4' />
                    </zone-style>
                  </zone>
                  <zone fixed-size='139' h='11583' id='4' is-fixed='true' layout-strategy-id='distribute-evenly' param='horz' type-v2='layout-flow' w='98770' x='615' y='9834'>
                    <zone h='11584' id='5' name='BAN Spread' show-title='false' w='32923' x='615' y='9833'>
                      <layout-cache cell-count-h='1' cell-count-w='1' type-h='cell' type-w='cell' />
