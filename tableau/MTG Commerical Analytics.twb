    <worksheet name='EV by Slot'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#edf1f6' fontname='Oswald' fontsize='14'>Where the Value Sits — EV by Slot</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#8a97a8' fontname='Montserrat' fontsize='9'>Sorted to match — see sort control</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#4fc4d6' fontname='Montserrat' fontsize='12'>● Wildcard </run>
            <run fontalignment='1' fontcolor='#e8b04b' fontname='Montserrat' fontsize='12'>● Special Guest / Bonus </run>
            <run fontalignment='1' fontcolor='#e0885b' fontname='Montserrat' fontsize='12'>● Rare / Mythic </run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#9b8ce0' fontname='Montserrat' fontsize='12'>● Foil</run>
            <run fontalignment='1' fontcolor='#e8b04b' fontname='Montserrat' fontsize='12'>Æ </run>
            <run fontalignment='1' fontcolor='#5a6b7d' fontname='Montserrat' fontsize='12'>● Common / Uncommon / Land</run>
            <run fontalignment='1' fontcolor='#e8b04b' fontname='Montserrat' fontsize='12'>Æ </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='ev_by_slot' name='federated.1hcxccr1ruuzp7113uyag164i0td' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Realizable value ÷ price' caption='p.Sort By' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='1'>
              <calculation class='tableau' formula='1' />
              <aliases>
                <alias key='1' value='Realizable value ÷ price' />
                <alias key='2' value='Nominal EV per pack' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1hcxccr1ruuzp7113uyag164i0td'>
            <column caption='Slot Group' datatype='string' name='[Calculation_1307616343023616]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF CONTAINS(LOWER([sheet]), &quot;specialguest&quot;) OR CONTAINS(LOWER([sheet]), &quot;list&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;breakingnews&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;mysticalarchive&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;sourcematerial&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;throughtheages&quot;)&#13;&#10;    OR CONTAINS(LOWER([sheet]), &quot;legendaryturtle&quot;)&#13;&#10;    THEN &quot;Special Guest / Bonus&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;wildcard&quot;) &#13;&#10;    THEN &quot;Wildcard&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;land&quot;) OR CONTAINS(LOWER([sheet]), &quot;basic&quot;) &#13;&#10;    THEN &quot;Common / Uncommon / Land&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;foil&quot;) &#13;&#10;    THEN &quot;Foil&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;rare&quot;) OR CONTAINS(LOWER([sheet]), &quot;mythic&quot;) &#13;&#10;    THEN &quot;Rare / Mythic&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([sheet]), &quot;common&quot;) OR CONTAINS(LOWER([sheet]), &quot;uncommon&quot;) &#13;&#10;    THEN &quot;Common / Uncommon / Land&quot;&#13;&#10;ELSE &quot;Other&quot; // nothing should hit Other&#13;&#10;END' />
            </column>
            <column caption='Slot Sort Key' datatype='real' name='[Calculation_2257594405265409]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 1&#13;&#10;    THEN SUM([slot_ev_realizable_contribution]) / MIN([sealed_price_usd])&#13;&#10;ELSE SUM([slot_ev_contribution])&#13;&#10;END' />
            </column>
            <column-instance column='[sheet_coverage]' derivation='Avg' name='[avg:sheet_coverage:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1307616343023616]' derivation='None' name='[none:Calculation_1307616343023616:nk]' pivot='key' type='nominal' />
            <column-instance column='[set_name]' derivation='None' name='[none:set_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[variant]' derivation='None' name='[none:variant:nk]' pivot='key' type='nominal' />
            <column-instance column='[slot_ev_contribution]' derivation='Sum' name='[pcto:sum:slot_ev_contribution:qk:4]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.1hcxccr1ruuzp7113uyag164i0td].[Calculation_1307616343023616]' ordering-type='Field' type='PctTotal' />
            </column-instance>
            <column caption='Sealed Price Usd' datatype='real' name='[sealed_price_usd]' role='measure' type='quantitative' />
            <column caption='Set Name' datatype='string' name='[set_name]' role='dimension' type='nominal' />
            <column caption='Sheet' datatype='string' name='[sheet]' role='dimension' type='nominal' />
            <column caption='Sheet Coverage' datatype='real' default-format='p0%' name='[sheet_coverage]' role='measure' type='quantitative' />
            <column caption='Slot Ev Contribution' datatype='real' default-format='*$#,##0.00' name='[slot_ev_contribution]' role='measure' type='quantitative' />
            <column caption='Slot Ev Realizable Contribution' datatype='real' name='[slot_ev_realizable_contribution]' role='measure' type='quantitative' />
            <column-instance column='[sheet_coverage]' derivation='Sum' name='[sum:sheet_coverage:qk]' pivot='key' type='quantitative' />
            <column-instance column='[slot_ev_contribution]' derivation='Sum' name='[sum:slot_ev_contribution:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2257594405265409]' derivation='User' name='[usr:Calculation_2257594405265409:qk]' pivot='key' type='quantitative' />
            <column caption='Variant' datatype='string' name='[variant]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <computed-sort column='[federated.1hcxccr1ruuzp7113uyag164i0td].[none:set_name:nk]' direction='DESC' using='[federated.1hcxccr1ruuzp7113uyag164i0td].[usr:Calculation_2257594405265409:qk]' />
          <filter class='categorical' column='[federated.1hcxccr1ruuzp7113uyag164i0td].[none:variant:nk]'>
            <groupfilter function='member' level='[none:variant:nk]' member='&quot;play&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.1hcxccr1ruuzp7113uyag164i0td].[none:variant:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
